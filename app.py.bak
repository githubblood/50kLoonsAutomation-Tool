/* ── Log ── */
#log-box {
  background: #07090f;
  border: 1px solid #111827;
  border-radius: 8px;
  height: 260px;
  overflow-y: auto;
  padding: 11px 13px;
  font-family: 'JetBrains Mono','Cascadia Code','Fira Code',monospace;
  font-size: .72rem;
  line-height: 1.7;
}
.ll   { white-space: pre-wrap; word-break: break-all; }
.ok   { color: #4ade80; }
.warn { color: #facc15; }
.err  { color: #f87171; }
.rty  { color: #fb923c; }
.done { color: #c4b5fd; font-weight: 600; }
