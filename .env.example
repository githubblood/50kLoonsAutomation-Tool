# --- Proxy Configuration ---
# none | file | env | rotating  — use "none" for current machine IP
PROXY_SOURCE=none

PROXY_LIST=
ROTATING_PROXY_URL=
ROTATING_PROXY_MOBILE_URL=
ROTATING_PROXY_FORCE_TYPE=

# --- Playwright ---
HEADLESS=true

# --- Misc ---
MAX_WORKERS=1
LOG_LEVEL=INFO
