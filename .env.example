# ============================================================
#  Lead Automation — Environment Variables
# ============================================================

# --- Google Sheets ---
# Path to your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

# The full URL or ID of your Google Sheet
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit

# Name of the worksheet tab to use
GOOGLE_SHEET_WORKSHEET=Sheet1

# --- Proxy Configuration ---
# Proxy source: "file" (proxies.txt), "env" (PROXY_LIST below), or "rotating" (single rotating endpoint)
PROXY_SOURCE=file

# If PROXY_SOURCE=env, provide comma-separated proxies here
# Format: protocol://user:pass@host:port  OR  protocol://host:port
PROXY_LIST=http://user:pass@proxy1.example.com:8080,socks5://user:pass@proxy2.example.com:1080

# If PROXY_SOURCE=rotating, provide the single rotating endpoint
ROTATING_PROXY_URL=http://user:pass@gate.smartproxy.com:7777

# --- Playwright ---
# Run browser headless? (true / false)
HEADLESS=true

# Anthropic / OpenAI key (reserved for future CAPTCHA-solving integration)
# CAPTCHA_API_KEY=

# --- Misc ---
# Max concurrent workers (currently sequential; reserved for future use)
MAX_WORKERS=1

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
